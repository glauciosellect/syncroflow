# Banco de dados (PostgreSQL com pgvector)
DATABASE_URL="postgresql://syncroflow:syncroflow123@localhost:5432/syncroflow"
DIRECT_URL="postgresql://syncroflow:syncroflow123@localhost:5432/syncroflow"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (gere strings aleatórias de 64+ chars)
JWT_SECRET="change-me-in-production-use-openssl-rand-hex-32"
JWT_REFRESH_SECRET="change-me-refresh-in-production-use-openssl-rand-hex-32"

# Criptografia AES-256 (32 bytes = 64 chars hex)
# openssl rand -hex 32
ENCRYPTION_KEY="change-me-32-bytes-hex-string-exactly-64-chars-here-00000000000000"

# LLMs
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# WhatsApp Provider
WHATSAPP_PROVIDER="evolution"   # ou "zapi"

# Evolution API (se WHATSAPP_PROVIDER=evolution)
EVOLUTION_API_URL="https://evolution.seu-dominio.com"
EVOLUTION_API_KEY="sua-evolution-api-key"

# Z-API (se WHATSAPP_PROVIDER=zapi)
ZAPI_BASE_URL="https://api.z-api.io"
ZAPI_CLIENT_TOKEN="seu-zapi-client-token"

# Meta (Instagram + Facebook)
META_APP_ID="seu-meta-app-id"
META_APP_SECRET="seu-meta-app-secret"
META_VERIFY_TOKEN="token-verificacao-webhook"

# URLs
API_URL="https://api.syncroflow.io"
FRONTEND_URL="https://app.syncroflow.io"

# Google OAuth (login com Google + Google Calendar)
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-seu-client-secret"

# Email (SMTP)
SMTP_HOST="smtp.seu-provedor.com"
SMTP_PORT=587
SMTP_USER="noreply@syncroflow.com"
SMTP_PASS="sua-senha-smtp"
SMTP_FROM="noreply@syncroflow.com"

# Supabase Storage (opcional)
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="seu-service-role-key"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs criados no Stripe Dashboard (opcional — sem eles cria prices dinamicamente)
# STRIPE_PRICE_BASIC_MONTHLY="price_..."
# STRIPE_PRICE_BASIC_ANNUAL="price_..."
# STRIPE_PRICE_STANDARD_MONTHLY="price_..."
# STRIPE_PRICE_STANDARD_ANNUAL="price_..."
# STRIPE_PRICE_CORPORATE_MONTHLY="price_..."
# STRIPE_PRICE_CORPORATE_ANNUAL="price_..."

# ElevenLabs TTS — voz JARVIS (opcional, usa OpenAI onyx como fallback)
# Crie conta em elevenlabs.io, gere uma API Key e escolha uma voz masculina grave
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# Sentry (opcional)
SENTRY_DSN=""

# Ambiente
NODE_ENV="development"
PORT=3001
