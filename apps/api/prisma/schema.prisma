generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String?
  phone            String?
  avatarUrl        String?
  googleId         String?           @unique
  language         String            @default("pt-br")
  theme            String            @default("light")
  twoFactorSecret  String?
  twoFactorEnabled Boolean           @default(false)
  onboardingDone   Boolean           @default(false)
  onboardingData   Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  apiKeys          ApiKey[]
  sessions         Session[]
  workspaceMembers WorkspaceMember[]
}

model Workspace {
  id                      String            @id @default(cuid())
  name                    String
  slug                    String            @unique
  plan                    Plan              @default(TRIAL)
  trialEndsAt             DateTime?
  credits                 Int               @default(1000)
  googleCalendarEnabled   Boolean           @default(false)
  googleCalendarEmail     String?
  googleCalendarId        String?
  googleAccessToken       String?
  googleRefreshToken      String?
  googleTokenExpiry       DateTime?
  elevenLabsKey           String?
  elevenLabsVoiceId       String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @default(now()) @updatedAt
  agents          Agent[]
  attendances     Attendance[]
  channels        Channel[]
  contacts        Contact[]
  conversations   Conversation[]
  envVariables    EnvVariable[]
  invoices        Invoice[]
  knowledgeBases  KnowledgeBase[]
  subscriptions   Subscription[]
  members         WorkspaceMember[]
  invites         WorkspaceInvite[]
  leads           Lead[]
  pipelineStages  PipelineStage[]
  followUps       FollowUp[]
  welcomeMessages WelcomeMessage[]
  integrations         Integration[]
  automations          Automation[]
  crmConnections       CrmConnection[]
  financeConnections   FinanceConnection[]
  marketingConnections MarketingConnection[]
  auditLogs            AuditLog[]
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  role        MemberRole @default(AGENT)
  userId      String
  workspaceId String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id          String     @id @default(cuid())
  workspaceId String
  email       String
  role        MemberRole @default(AGENT)
  token       String     @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([email, workspaceId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  lastUsedAt  DateTime?
  userId      String
  workspaceId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agent {
  id                 String               @id @default(cuid())
  name               String
  avatarUrl          String?
  purpose            AgentPurpose         @default(SUPPORT)
  companyName        String?
  companyWebsite     String?
  companyDesc        String?
  behavior           String?
  communicationStyle CommunicationStyle   @default(NORMAL)
  llmModel           String               @default("claude-haiku-4-5")
  workspaceId        String
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now()) @updatedAt
  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentChannels      AgentChannel[]
  config             AgentConfig?
  integrations       AgentIntegration[]
  knowledgeBases     AgentKnowledgeBase[]
  mcpServers         AgentMcpServer[]
  conversations      Conversation[]
  intentions         Intention[]
  trainings          Training[]
  flows              Flow[]
}

model AgentConfig {
  id                     String   @id @default(cuid())
  agentId                String   @unique
  transferToHuman        Boolean  @default(true)
  summarizeOnTransfer    Boolean  @default(false)
  useEmojis              Boolean  @default(false)
  signNameInResponses    Boolean  @default(false)
  restrictTopics         Boolean  @default(false)
  splitLongMessages      Boolean  @default(false)
  allowReminders         Boolean  @default(true)
  smartTrainingSearch    Boolean  @default(false)
  timezone               String   @default("America/Sao_Paulo")
  responseDelay          Int      @default(0)
  maxInteractionsPerChat Int?
  workingHours           Json?
  webhookEvents          Json?
  transferRules          Json?
  inactivityActions      Json?
  autoCreateLead         Boolean  @default(false)
  autoLeadStageId        String?
  firstContactEnabled    Boolean  @default(false)
  firstContactText       String?
  firstContactVideoUrl   String?
  firstContactFileUrl    String?
  firstContactFileName   String?
  ttsVoice               String   @default("onyx")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt
  agent                  Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Training {
  id         String          @id @default(cuid())
  agentId    String
  type       TrainingType
  title      String?
  content    String?
  url        String?
  fileUrl    String?
  fileName   String?
  fileSize   Int?
  status     TrainingStatus  @default(PENDING)
  errorMsg   String?
  chunkCount Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt
  agent      Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chunks     TrainingChunk[]
}

model TrainingChunk {
  id         String                 @id @default(cuid())
  trainingId String
  content    String
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now())
  training   Training               @relation(fields: [trainingId], references: [id], onDelete: Cascade)
}

model KnowledgeBase {
  id          String               @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @default(now()) @updatedAt
  agentLinks  AgentKnowledgeBase[]
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   KnowledgeDocument[]
}

model KnowledgeDocument {
  id              String           @id @default(cuid())
  knowledgeBaseId String
  title           String
  content         String
  fileUrl         String?
  fileName        String?
  status          TrainingStatus   @default(PENDING)
  chunkCount      Int              @default(0)
  createdAt       DateTime         @default(now())
  chunks          KnowledgeChunk[]
  knowledgeBase   KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
}

model KnowledgeChunk {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now())
  document   KnowledgeDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model AgentKnowledgeBase {
  agentId         String
  knowledgeBaseId String
  createdAt       DateTime      @default(now())
  agent           Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@id([agentId, knowledgeBaseId])
}

model Intention {
  id                String                @id @default(cuid())
  agentId           String
  name              String
  description       String?
  fields            Json?
  actionType        IntentionAction       @default(WEBHOOK)
  calendarAction    String?
  transferToAgentId String?
  webhookUrl        String?
  webhookMethod     String                @default("POST")
  webhookHeaders    Json?
  webhookParams     Json?
  webhookBody       Json?
  outputVariables   Json?
  responseMode      IntentionResponseMode @default(INTERPRET_API)
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @default(now()) @updatedAt
  agent             Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Flow {
  id          String   @id @default(cuid())
  agentId     String
  name        String
  trigger     String
  script      String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Channel {
  id            String         @id @default(cuid())
  workspaceId   String
  type          ChannelType
  name          String
  isActive      Boolean        @default(true)
  config        Json
  webhookSecret String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  agentChannels AgentChannel[]
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]
}

model AgentChannel {
  agentId   String
  channelId String
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([agentId, channelId])
}

model Contact {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String?
  phone         String?
  email         String?
  avatarUrl     String?
  channelId     String?
  externalId    String?
  variables     Json?
  tags          String[]       @default([])
  notes         String?
  humanOnly     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([workspaceId, channelId, externalId])
}

model Conversation {
  id               String             @id @default(cuid())
  workspaceId      String
  agentId          String
  channelId        String
  contactId        String
  status           ConversationStatus @default(AI_ACTIVE)
  assignedToId     String?
  protocol         String             @unique @default(cuid())
  startedAt        DateTime           @default(now())
  endedAt          DateTime?
  creditsUsed      Int                @default(0)
  interactionCount Int                @default(0)
  transferSummary  String?
  closedBy         String?
  unreadCount      Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @default(now()) @updatedAt
  agent            Agent              @relation(fields: [agentId], references: [id])
  channel          Channel            @relation(fields: [channelId], references: [id])
  contact          Contact            @relation(fields: [contactId], references: [id])
  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages         Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  mediaUrl       String?
  mediaType      String?
  creditsUsed    Int          @default(0)
  intentionId    String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Attendance {
  id               String      @id @default(cuid())
  workspaceId      String
  conversationId   String      @unique
  contactName      String?
  contactPhone     String?
  channelType      ChannelType
  agentName        String
  assigneeName     String?
  status           String
  startedAt        DateTime
  endedAt          DateTime?
  durationSeconds  Int?
  creditsUsed      Int         @default(0)
  interactionCount Int         @default(0)
  protocol         String
  createdAt        DateTime    @default(now())
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AgentIntegration {
  id        String          @id @default(cuid())
  agentId   String
  type      IntegrationType
  isActive  Boolean         @default(true)
  config    Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt
  agent     Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, type])
}

model AgentMcpServer {
  id        String   @id @default(cuid())
  agentId   String
  name      String
  url       String
  apiKey    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model EnvVariable {
  id          String     @id @default(cuid())
  workspaceId String
  key         String
  value       String
  type        EnvVarType @default(TEXT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
}

model Subscription {
  id                 String             @id @default(cuid())
  workspaceId        String
  plan               Plan
  billingCycle       BillingCycle       @default(MONTHLY)
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  externalId         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  workspace          Workspace          @relation(fields: [workspaceId], references: [id])
}

model Invoice {
  id          String    @id @default(cuid())
  workspaceId String
  amount      Int
  status      String
  pdfUrl      String?
  externalId  String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Lead {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  phone       String?
  email       String?
  source      String?
  notes       String?
  tags        String[]       @default([])
  stageId     String?
  contactId   String?
  agentId     String?
  value       Float?
  lostReason  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stage       PipelineStage? @relation(fields: [stageId], references: [id])
  followUps   FollowUp[]
}

model PipelineStage {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  color       String    @default("#1565C0")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads       Lead[]
}

model FollowUp {
  id          String         @id @default(cuid())
  workspaceId String
  leadId      String?
  contactId   String?
  title       String
  notes       String?
  scheduledAt DateTime
  doneAt      DateTime?
  status      FollowUpStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead        Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model WelcomeMessage {
  id           String    @id @default(cuid())
  workspaceId  String
  userId       String
  phone        String
  name         String
  messageIndex Int
  scheduledAt  DateTime
  sentAt       DateTime?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum Plan {
  TRIAL
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  AGENT
  VIEWER
}

enum AgentPurpose {
  SUPPORT
  SALES
  PERSONAL
}

enum CommunicationStyle {
  FORMAL
  NORMAL
  CASUAL
}

enum TrainingType {
  TEXT
  WEBSITE
  VIDEO
  DOCUMENT
}

enum TrainingStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

enum IntentionAction {
  WEBHOOK
  INTERNAL
  CALENDAR
  AGENT_TRANSFER
}

enum IntentionResponseMode {
  INTERPRET_API
  FIXED_MESSAGE
  API_RAW
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  TELEGRAM
  WIDGET
  EMAIL
  SMS
  LINKEDIN
}

enum ConversationStatus {
  AI_ACTIVE
  WAITING_HUMAN
  HUMAN_ACTIVE
  CLOSED
}

enum MessageRole {
  USER
  ASSISTANT
  HUMAN
  SYSTEM
}

enum FollowUpStatus {
  PENDING
  DONE
  CANCELLED
}

enum IntegrationType {
  ELEVEN_LABS
  GOOGLE_CALENDAR
  PLUG_CHAT
  E_VENDI
  SHOPIFY
  STRIPE
  PAYPAL
  INVIDEO
}

enum EnvVarType {
  TEXT
  NUMBER
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

model Integration {
  id             String       @id @default(cuid())
  workspaceId    String
  platform       String
  status         String       @default("active")
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  shopId         String?
  shopName       String?
  shopUrl        String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  automations    Automation[]

  @@unique([workspaceId, platform])
}

model Automation {
  id            String                @id @default(cuid())
  workspaceId   String
  integrationId String
  name          String
  trigger       String
  actions       Json
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now()) @updatedAt
  workspace     Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration   Integration           @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  executions    AutomationExecution[]
}

model AutomationExecution {
  id           String     @id @default(cuid())
  automationId String
  status       String
  triggerData  Json
  result       Json?
  errorMsg     String?
  createdAt    DateTime   @default(now())
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

// ─── CRM Integrations (M4) ────────────────────────────────────────────────────

model CrmConnection {
  id           String    @id @default(cuid())
  workspaceId  String
  platform     String    // 'hubspot' | 'pipedrive' | 'rdcrm'
  status       String    @default("active")
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?
  accountId    String?
  accountName  String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
}

// ─── Finance Integrations (M5) ───────────────────────────────────────────────

model FinanceConnection {
  id          String    @id @default(cuid())
  workspaceId String
  platform    String    // 'asaas' | 'pagarme'
  status      String    @default("active")
  apiKey      String?
  accountId   String?
  accountName String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
}

// ─── Marketing Integrations (M6) ─────────────────────────────────────────────

model MarketingConnection {
  id           String    @id @default(cuid())
  workspaceId  String
  platform     String    // 'rdmarketing' | 'activecampaign'
  status       String    @default("active")
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?
  apiKey       String?
  accountUrl   String?
  accountId    String?
  accountName  String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
}

// ─── Audit Log (M8) ──────────────────────────────────────────────────────────

model AuditLog {
  id           String    @id @default(cuid())
  workspaceId  String
  userId       String?
  action       String    // 'workflow.created' | 'integration.connected' | etc
  resourceType String?
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Public Templates Marketplace (M10) ──────────────────────────────────────

model PublicTemplate {
  id                 String    @id @default(cuid())
  title              String
  description        String?
  category           String    // 'ecommerce' | 'crm' | 'finance' | 'marketing' | 'ai' | 'general'
  connectorsRequired String[]  @default([])
  workflowConfig     Json
  usesCount          Int       @default(0)
  isFeatured         Boolean   @default(false)
  isApproved         Boolean   @default(true)
  createdByWorkspace String?
  tags               String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt
}

